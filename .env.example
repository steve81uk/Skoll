# SKÖLL-TRACK — Environment Configuration Template
# Copy as .env and fill in values before running

# ── Client/API keys (Vite) ──────────────────────────────────────────────────
VITE_NASA_API_KEY=
VITE_NASA_DONKI_API_KEY=
VITE_OPENWEATHER_API_KEY=
VITE_MAPBOX_TOKEN=
VITE_NASA_FIREBALL_PROXY_URL=
VITE_NOAA_API_KEY=
VITE_ENABLE_REMOTE_WMM=false

# Frontend -> backend routing (Vercel to Render)
VITE_BACKEND_HTTP_BASE=http://localhost:8080
VITE_BACKEND_WS_URL=ws://localhost:8080
VITE_EPHEMERIS_API_BASE=http://localhost:8080
VITE_ALERT_RELAY_URL=http://localhost:8080/api/alerts/social-relay
VITE_DEBUG_LOGS=false

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# ── TF.js Model path (relative to project root) ─────────────────────────────
MODEL_PATH=./public/models/skoll-lstm-v1/model.json

# ── NOAA/DONKI data fetch interval in milliseconds ──────────────────────────
FETCH_INTERVAL_MS=60000

# ── Log level: debug | info | warn | error ───────────────────────────────────
LOG_LEVEL=info

# Optional override for NOAA plasma endpoint
NOAA_API=https://services.swpc.noaa.gov/products/solar-wind/plasma-1-day.json

# Generic outbound relay webhook (Make/n8n/Zapier/etc.)
SOCIAL_RELAY_WEBHOOK=
AUTO_RELAY_ENABLED=false

# Direct X relay posting
X_RELAY_ENABLED=false
X_BEARER_TOKEN=
X_RELAY_DEFAULT_TAGS=#SpaceWeather #SkollTrack
