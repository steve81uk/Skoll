# SKÖLL-TRACK — Environment Configuration Template
# Copy as .env and fill in values before running

# ── Client/API keys (Vite) ──────────────────────────────────────────────────
VITE_NASA_API_KEY=
VITE_NASA_DONKI_API_KEY=
VITE_OPENWEATHER_API_KEY=
VITE_MAPBOX_TOKEN=

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# ── TF.js Model path (relative to project root) ─────────────────────────────
MODEL_PATH=./public/models/skoll-lstm-v1/model.json

# ── NOAA/DONKI data fetch interval in milliseconds ──────────────────────────
FETCH_INTERVAL_MS=60000

# ── Log level: debug | info | warn | error ───────────────────────────────────
LOG_LEVEL=info
